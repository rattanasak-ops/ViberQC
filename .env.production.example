# ============================================================
# ViberQC — Production Environment Variables
# Copy values จาก service dashboards แต่ละตัว
# ห้าม commit ไฟล์นี้ถ้ามีค่าจริง!
# ============================================================

# --- Database ---
# สร้าง production DB บน Supabase/Neon/Railway
DATABASE_URL=postgresql://user:password@prod-host:5432/viberqc

# --- Auth ---
# เปลี่ยน URL เป็น production domain
NEXTAUTH_URL=https://viberqc.com
# สร้างใหม่: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_NEW_SECRET_HERE

# --- Google OAuth ---
# เพิ่ม redirect URI: https://viberqc.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GitHub OAuth ---
# เปลี่ยน callback URL เป็น: https://viberqc.com/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Stripe (LIVE keys — ไม่ใช่ test!) ---
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# สร้าง webhook endpoint ใหม่สำหรับ https://viberqc.com/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (Resend) ---
# สมัคร resend.com → สร้าง API key
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@viberqc.com

# --- AI Models ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=...

# --- Sentry (Error Monitoring) ---
# สมัคร sentry.io → สร้าง project → copy DSN
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# สำหรับ upload source maps: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_...

# --- App ---
NEXT_PUBLIC_APP_URL=https://viberqc.com
NEXT_PUBLIC_APP_NAME=ViberQC
