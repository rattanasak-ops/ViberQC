# ============================================================
# ViberQC — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/viberqc

# --- Auth (NextAuth.js v5) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI Models (ใส่อย่างน้อย 1 ตัว — แนะนำ OpenRouter) ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
XAI_GROK_API_KEY=

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
FROM_EMAIL=noreply@viberqc.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:6161
NEXT_PUBLIC_APP_NAME=ViberQC

# ============================================================
# Add-on API Integrations (ใส่เฉพาะตัวที่ใช้)
# ============================================================

# --- Security APIs ---
SNYK_API_TOKEN=
DETECTIFY_API_KEY=
STACKHAWK_API_KEY=
INTRUDER_API_KEY=
QUALYS_API_KEY=
TENABLE_API_KEY=

# --- Performance APIs ---
GTMETRIX_API_KEY=
WEBPAGETEST_API_KEY=
SPEEDCURVE_API_KEY=
DEBUGBEAR_API_KEY=
DATADOG_API_KEY=

# --- SEO APIs ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
AHREFS_API_TOKEN=
SEMRUSH_API_KEY=
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=
MAJESTIC_API_KEY=

# --- Accessibility APIs ---
WAVE_API_KEY=
AXE_DEVTOOLS_API_KEY=

# --- Code Quality APIs ---
SONARCLOUD_TOKEN=
CODACY_API_TOKEN=
CODECLIMATE_API_KEY=

# --- Cross-Browser APIs ---
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
LAMBDATEST_USERNAME=
LAMBDATEST_ACCESS_KEY=

# --- Uptime Monitoring APIs ---
UPTIMEROBOT_API_KEY=
PINGDOM_API_TOKEN=
STATUSCAKE_API_KEY=
BETTER_STACK_API_TOKEN=
CHECKLY_API_KEY=

# --- Report Generation ---
DOCRAPTOR_API_KEY=
GOTENBERG_URL=http://localhost:3000
